# see models here: https://ai.google.dev/gemini-api/docs/models
# see pricing here: https://ai.google.dev/gemini-api/docs/pricing

# Project name
PROJECT_NAME="TAIPO: AI-Kanban"

# Counter Limits
MAX_TITLE_LENGTH=42
MAX_DESCRIPTION_LENGTH=512
MAX_QUERY_LENGTH=1320

# Google Gemini API
GEMINI_API_KEY="AIzaSy...your-api-key-here"
GEMINI_BASE_MODEL="gemini-3-flash-preview"
GEMINI_FALLBACK_MODEL="gemini-2.5-flash"
# GEMINI_FALLBACK_MODEL="gemini-2.5-flash-lite"
GEMINI_BASE_URL="https://generativelanguage.googleapis.com/v1beta"
GEMINI_FALLBACK_URL="https://generativelanguage.googleapis.com/v1beta"

# Google Gemini costs
GEMINI_BASE_MODEL_PROMPT_COST_PER_MILLION=0.500  # gemini-3-flash-preview INPUT  # 2026-02-25
GEMINI_BASE_MODEL_CANDIDATE_COST_PER_MILLION=3.000  # gemini-3-flash-preview OUTPUT  # 2026-02-25
GEMINI_FALLBACK_MODEL_PROMPT_COST_PER_MILLION=0.300  # gemini-2.5-flash INPUT  # 2026-02-25
GEMINI_FALLBACK_MODEL_CANDIDATE_COST_PER_MILLION=2.500  # gemini-2.5-flash OUTPUT  # 2026-02-25

# GEMINI_FALLBACK_MODEL_PROMPT_COST_PER_MILLION=0.250  # gemini-3.1-flash-lite-preview INPUT  # 2026-03-06
# GEMINI_FALLBACK_MODEL_CANDIDATE_COST_PER_MILLION=1.500  # gemini-3.1-flash-lite-preview OUTPUT  # 2026-03-06
# GEMINI_FALLBACK_MODEL_PROMPT_COST_PER_MILLION=0.100  # gemini-2.5-flash-lite INPUT  # 2026-02-25
# GEMINI_FALLBACK_MODEL_CANDIDATE_COST_PER_MILLION=0.400  # gemini-2.5-flash-lite OUTPUT  # 2026-02-25


# TAIPO settings
GEMINI_TEMPERATURE=0.7
GEMINI_TOP_K=40
GEMINI_TOP_P=0.95
GEMINI_MAX_OUTPUT_TOKENS=4096

# Users
MIN_USERNAME_LENGTH=6
MIN_PASSWORD_LENGTH=8

# GitHub
GITHUB_USERNAME="your-github-username"
GITHUB_REPO="your-github-repo"
GITHUB_TOKEN="your-github-token"
GITHUB_USERAGENT="AI-Kanban-App"

# CORS allowed origins
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:5173,http://localhost:8000"


# Database configuration
# If SQLITE_FILE_NAME is set, SQLite will be used.
# Case-insensitive "None" or empty string means a server-based DB is used.
SQLITE_FILE_NAME="ai_kanban.db"

# Used if SQLITE_FILE_NAME is not set (mysql, mariadb, pgsql, sqlsrv, oci)
DB_TYPE="sqlite"

# IF NOT USING SQLITE
# DB_TYPE="mysql"
# DB_PORT=3306
# DB_TYPE="mariadb"  # uses "mysql" connector
# DB_PORT=3306  # uses "mysql" port
# DB_TYPE="pgsql"
# DB_PORT=5432
# DB_TYPE="sqlsrv"
# DB_PORT=1433
# DB_TYPE="oci"
# DB_PORT=1521
DB_HOST="localhost"
DB_NAME="db_name"
DB_USER="db_username"
DB_PASS="db_passwd"

# Optional table prefix (leave empty for none)
TABLE_PREFIX="taipo_"

# Registration
REGISTRATION_ENABLED=true
