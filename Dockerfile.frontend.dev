# ============================================================
# TAIPO: AI-Driven Kanban Board — Frontend Dev Service
# ============================================================
FROM node:22.22.2-alpine3.22

WORKDIR /app/frontend

# Install pnpm
RUN corepack enable && corepack prepare pnpm@latest --activate

# In dev, we expect package.json and pnpm-lock.yaml to be mounted or copied
# We run install to ensure node_modules is populated in the volume if needed
# But usually, it's better to run pnpm install in the CMD to stay in sync with host
COPY package.json pnpm-lock.yaml ./
RUN pnpm install

EXPOSE 5173

# Run Vite with --host to allow external access within Docker network
CMD ["pnpm", "dev", "--host"]
